{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "luma",
  "name": "Verak Docs",
  "logo": {
    "dark": "/logo/dark.png",
    "light": "/logo/light.png",
    "href": "https://verak.app"
  },
  "favicon": "/favicon.svg",
  "colors": {
    "primary": "#00A3FF",
    "light": "#00A3FF",
    "dark": "#00A3FF"
  },
  "backgroundImage": "/images/background.png",
  "modeToggle": {
    "default": "dark",
    "isHidden": false
  },
  "navbar": {
    "links": [
      {
        "label": "Verak",
        "href": "https://verak.app"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get Started",
      "href": "https://verak.app/get-started"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Docs",
        "groups": [
          {
            "group": "Overview",
            "pages": ["introduction"]
          },
          {
            "group": "Trust Infrastructure",
            "pages": ["trust-gateway", "lexicon-reference"]
          },
          {
            "group": "Integrate Verak Trust",
            "pages": [
              "integrate/overview",
              "integrate/labeler",
              "integrate/credentials",
              "integrate/trust-api"
            ]
          },
          {
            "group": "Resources",
            "pages": ["trust-statement", "changelog"]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Verak",
          "icon": "arrow-up-right-from-square",
          "href": "https://verak.app"
        },
        {
          "anchor": "AT Protocol",
          "icon": "atom",
          "href": "https://atproto.com"
        }
      ]
    }
  },
  "footer": {
    "socials": {
      "bluesky": "https://bsky.app/profile/verak.app",
      "github": "https://github.com/verak"
    }
  },
  "feedback": {
    "thumbsRating": true,
    "suggestEdit": true,
    "raiseIssue": true
  },
  "metadata": {
    "og:title": "Verak Developer Docs",
    "og:description": "Technical documentation for the Verak Trust Gateway, AT Protocol lexicons, and sovereign professional identity infrastructure.",
    "og:image": "https://docs.verak.dev/images/og-card.png",
    "twitter:card": "summary_large_image"
  }
}
