{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "luma",
  "name": "Kevara Docs",
  "logo": {
    "dark": "/logo/dark.svg",
    "light": "/logo/light.svg",
    "href": "https://kevara.co"
  },
  "favicon": "/favicon.svg",
  "colors": {
    "primary": "#00A3FF",
    "light": "#00A3FF",
    "dark": "#00A3FF"
  },
  "backgroundImage": "/images/background.png",
  "modeToggle": {
    "default": "dark",
    "isHidden": false
  },
  "navbar": {
    "links": [
      {
        "label": "Kevara App",
        "href": "https://kevara.app"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get Started",
      "href": "https://www.kevara.co/get-started.html"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Docs",
        "groups": [
          {
            "group": "Overview",
            "pages": ["introduction"]
          },
          {
            "group": "Trust Infrastructure",
            "pages": ["trust-gateway", "lexicon-reference"]
          },
          {
            "group": "Resources",
            "pages": ["trust-statement", "changelog"]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Trust Gateway",
          "icon": "shield-check",
          "href": "https://trust.kevara.co"
        },
        {
          "anchor": "Kevara App",
          "icon": "arrow-up-right-from-square",
          "href": "https://kevara.app"
        },
        {
          "anchor": "AT Protocol",
          "icon": "atom",
          "href": "https://atproto.com"
        }
      ]
    }
  },
  "footer": {
    "socials": {
      "bluesky": "https://bsky.app/profile/kevara.app",
      "github": "https://github.com/kevara"
    }
  },
  "feedback": {
    "thumbsRating": true,
    "suggestEdit": true,
    "raiseIssue": true
  },
  "metadata": {
    "og:title": "Kevara Developer Docs",
    "og:description": "Technical documentation for the Kevara Trust Gateway, AT Protocol lexicons, and sovereign professional identity infrastructure.",
    "og:image": "https://docs.kevara.app/images/og-card.png",
    "twitter:card": "summary_large_image"
  }
}
